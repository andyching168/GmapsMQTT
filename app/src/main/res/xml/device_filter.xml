<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- USB Serial 裝置過濾器 -->
    <!-- 當這些裝置插入時，系統會詢問是否要使用此 App 開啟 -->

    <!-- CP2102 USB to UART Bridge (Silicon Labs) - 常見於 ESP32 開發板 -->
    <usb-device vendor-id="4292" product-id="60000" />

    <!-- CH340 USB to Serial (WCH) - 常見於便宜的 ESP32 開發板 -->
    <usb-device vendor-id="6790" product-id="29987" />
    <usb-device vendor-id="6790" product-id="29988" />

    <!-- FTDI FT232R USB UART -->
    <usb-device vendor-id="1027" product-id="24577" />

    <!-- CP2104 USB to UART Bridge -->
    <usb-device vendor-id="4292" product-id="60004" />

    <!-- 如果你的 ESP32 使用其他晶片，可以在這裡添加對應的 vendor-id 和 product-id -->
    <!-- 格式: <usb-device vendor-id="十進制VID" product-id="十進制PID" /> -->
</resources>
